# Quote-form email delivery (Resend) — server-only, never exposed to the client.
# Copy to `.env` for local dev; set the same keys in Vercel → Project Settings →
# Environment Variables for Preview/Production. Do NOT commit real values.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Business inbox that receives quote requests
QUOTE_TO_EMAIL=

# Verified sender address. For local/testing you can use: onboarding@resend.dev
QUOTE_FROM_EMAIL=
